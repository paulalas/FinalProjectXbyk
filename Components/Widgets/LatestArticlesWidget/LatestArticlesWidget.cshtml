@using FinalProject
@using FinalProject.Widgets
@using CMS.Websites

@model FinalProject.Widgets.LatestArticlesWidgetViewModel

<style>
    .articles-widget {
        padding: 80px 0 60px;
        background: #F6F6F6;
    }

    .articles-widget .section-title {
        padding-bottom: 50px;
        overflow: hidden;
    }

    .articles-widget .section-title h2 {
        font-weight: 600;
        font-size: 35px;
        color: #232323;
    }

    .articles-widget .section-title h2 span {
        color: #28ABE3;
    }

    .articles-widget .section-title .title-border {
        height: 2px;
        margin: 20px auto;
        width: 80px;
        background: #28ABE3;
    }

    .articles-widget .section-title p {
        color: #848484;
        margin: 0 auto;
    }

    .articles-widget .post-item {
        background: #fff;
        margin-bottom: 30px;
    }

    .articles-widget .post-item .media-wrapper img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }

    .articles-widget .post-item .content {
        padding: 20px;
    }

    .articles-widget .post-item .content h3 a {
        color: #000;
        text-decoration: none;
    }

    .articles-widget .post-item .content h3 a:hover {
        color: #28ABE3;
    }

    .articles-widget .post-item .content p {
        color: #757575;
        margin: 10px 0;
    }

    .articles-widget .btn-article {
        background: #28ABE3;
        border: 1px solid #28ABE3;
        color: #fff;
        display: inline-block;
        font-size: 14px;
        letter-spacing: 1px;
        padding: 12px 25px;
        text-transform: uppercase;
        border-radius: 40px;
        text-decoration: none;
        margin: 15px 0;
        transition: opacity 0.3s ease;
    }

    .articles-widget .btn-article:hover {
        opacity: 0.8;
        color: #fff;
        text-decoration: none;
    }
</style>

<section class="articles-widget">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-8">
                <div class="section-title text-center">
                    <h2>@Model.SectionTitle.Replace(Model.SectionTitleHighlight, "").Trim() <span>@Model.SectionTitleHighlight</span></h2>
                    <div class="title-border"></div>
                    @if (!string.IsNullOrEmpty(Model.SectionSubtitle))
                    {
                        <p>@Model.SectionSubtitle</p>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var article in Model.Articles)
            {
                var thumbnailUrl = article.ArticleThumbnail?.FirstOrDefault()?.Thumbnail?.Url ?? "";
                var articleUrl = Url.Content(article.GetUrl().RelativePath);
                var plainContent = System.Text.RegularExpressions.Regex.Replace(article.ArticleContent ?? "", "<.*?>", "");
                var excerpt = plainContent.Length > 150 ? plainContent.Substring(0, 150) + "..." : plainContent;

                <article class="col-lg-4 col-md-6">
                    <div class="post-item">
                        @if (!string.IsNullOrEmpty(thumbnailUrl))
                        {
                            <div class="media-wrapper">
                                <img loading="lazy" src="@thumbnailUrl" alt="@article.ArticleTitle" class="img-fluid">
                            </div>
                        }
                        <div class="content">
                            <h3><a href="@articleUrl">@article.ArticleTitle</a></h3>
                            <p>@excerpt</p>
                            <a class="btn-article" href="@articleUrl">Read more</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
