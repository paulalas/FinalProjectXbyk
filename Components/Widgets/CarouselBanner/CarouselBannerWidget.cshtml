@using FinalProject
@using FinalProject.Widgets
@using Kentico.PageBuilder.Web.Mvc

@model FinalProject.Widgets.CarouselBannerWidgetViewModel

@{
    var carouselId = $"carousel_{Guid.NewGuid().ToString("N").Substring(0, 8)}";
    var carouselItems = Model?.CarouselItems ?? new List<CarouselBannerItemViewModel>();
}

<style>
    .hero-carousel {
        height: 100vh;
        overflow: hidden;
    }

    .hero-carousel .carousel-inner {
        height: 100%;
        overflow: hidden;
    }

    .hero-carousel .carousel-item {
        height: 100%;
        background-size: cover;
        background-position: center;
    }

    .hero-carousel .carousel-item::before {
        content: "";
        background: rgba(0, 0, 0, 0.63);
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
    }

    .hero-carousel .slide-inner {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .hero-carousel .hero-content {
        color: #fff;
        text-align: center;
    }

    .hero-carousel .hero-content h1 {
        font-size: 60px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 20px;
        line-height: 1.2;
    }

    .hero-carousel .hero-content p {
        color: #fff;
        font-size: 16px;
        margin: 0 auto 30px;
        max-width: 600px;
        line-height: 1.7;
    }

    .hero-carousel .btn-hero {
        background: #28ABE3;
        border: 1px solid #28ABE3;
        color: #fff;
        display: inline-block;
        font-size: 14px;
        letter-spacing: 1px;
        padding: 12px 40px;
        text-transform: uppercase;
        border-radius: 40px;
        text-decoration: none;
        transition: opacity 0.3s ease;
    }

    .hero-carousel .btn-hero:hover {
        opacity: 0.8;
        color: #fff;
        text-decoration: none;
    }

    .hero-carousel .carousel-control-prev,
    .hero-carousel .carousel-control-next {
        width: 50px;
        height: 50px;
        top: 50%;
        transform: translateY(-50%);
        background-color: rgba(255, 255, 255, 0.15);
        border-radius: 50%;
        opacity: 0.8;
        transition: background-color 0.3s ease;
    }

    .hero-carousel .carousel-control-prev:hover,
    .hero-carousel .carousel-control-next:hover {
        background-color: rgba(255, 255, 255, 0.3);
        opacity: 1;
    }

    .hero-carousel .carousel-indicators [data-bs-target] {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.6);
        border: none;
    }

    .hero-carousel .carousel-indicators .active {
        background-color: #28ABE3;
    }

    @@media (max-width: 768px) {
        .hero-carousel .hero-content h1 {
            font-size: 36px;
        }

        .hero-carousel .hero-content p {
            font-size: 14px;
        }
    }
</style>

@if (carouselItems.Any())
{
    <div id="@carouselId" class="carousel hero-carousel slide" data-bs-ride="carousel">

        @if (carouselItems.Count > 1)
        {
            <div class="carousel-indicators">
                @for (int i = 0; i < carouselItems.Count; i++)
                {
                    <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
        }

        <div class="carousel-inner">
            @for (int i = 0; i < carouselItems.Count; i++)
            {
                var itemVm = carouselItems[i];
                var item = itemVm.Item;
                var backgroundImage = item.BackgroundPicture?.FirstOrDefault()?.Thumbnail?.Url ?? "";
                var buttonUrl = Url.Content(itemVm.ButtonUrl ?? "");

                <div class="carousel-item @(i == 0 ? "active" : "")"
                     style="background-image: url('@backgroundImage');">
                    <div class="slide-inner">
                        <div class="container">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="hero-content">
                                        @if (!string.IsNullOrEmpty(item.Title))
                                        {
                                            <h1>@item.Title</h1>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Content))
                                        {
                                            <p>@Html.Raw(item.Content)</p>
                                        }
                                        @if (!string.IsNullOrEmpty(item.ButtonText) && !string.IsNullOrEmpty(buttonUrl))
                                        {
                                            <a href="@buttonUrl" class="btn-hero">@item.ButtonText</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (carouselItems.Count > 1)
        {
            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        No carousel items configured for this widget.
    </div>
}
