@using Kentico.PageBuilder.Web.Mvc
@using FinalProject.Widgets

@model CarouselBannerWidgetProperties

@{
    var carouselItems = Model?.CarouselItems?.ToList() ?? new List<CarouselBanner>();
}

@if (carouselItems.Any())
{
    <div id="carouselBannerWidget" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <!-- Carousel Indicators -->
        <div class="carousel-indicators">
            @for (int i = 0; i < carouselItems.Count; i++)
            {
                <button type="button" data-bs-target="#carouselBannerWidget" data-bs-slide-to="@i" 
                        class="@(i == 0 ? "active" : "")" 
                        aria-label="Slide @(i + 1)"></button>
            }
        </div>

        <!-- Carousel Items -->
        <div class="carousel-inner">
            @for (int i = 0; i < carouselItems.Count; i++)
            {
                var item = carouselItems[i];
                var backgroundImage = item.BackgroundPicture?.FirstOrDefault()?.Thumbnail?.Url ?? "";
                var buttonLink = item.ButtonLink?.FirstOrDefault();

                <div class="carousel-item @(i == 0 ? "active" : "")" 
                     style="background-image: url('@backgroundImage'); background-size: cover; background-position: center; min-height: 500px;">
                    
                    <!-- Dark overlay for better text readability -->
                    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.4);"></div>

                    <!-- Text Content Overlay -->
                    <div class="d-flex flex-column justify-content-center align-items-center h-100" style="position: relative; z-index: 1;">
                        
                        <!-- Title - Center Top -->
                        @if (!string.IsNullOrEmpty(item.Title))
                        {
                            <h2 class="carousel-title text-white text-center mb-4" style="font-size: 3rem; font-weight: bold;">
                                @item.Title
                            </h2>
                        }

                        <!-- Content - Center Mid -->
                        @if (!string.IsNullOrEmpty(item.Content))
                        {
                            <div class="carousel-content text-white text-center mb-5" style="max-width: 600px; font-size: 1.1rem;">
                                @Html.Raw(item.Content)
                            </div>
                        }

                        <!-- Button - Center Bottom -->
                        @if (!string.IsNullOrEmpty(item.ButtonText) && buttonLink != null)
                        {
                            <a href="@buttonLink.WebPageRelatedItemUrl" class="btn btn-primary btn-lg">
                                @item.ButtonText
                            </a>
                        }
                        else if (!string.IsNullOrEmpty(item.ButtonText))
                        {
                            <button class="btn btn-primary btn-lg" disabled>
                                @item.ButtonText
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Carousel Controls -->
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselBannerWidget" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselBannerWidget" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <style>
        .carousel-fade .carousel-item {
            opacity: 0;
            transition-property: opacity;
            transition-duration: 0.6s;
        }

        .carousel-fade .carousel-item.active {
            opacity: 1;
        }

        .carousel-title {
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        }

        .carousel-content {
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            filter: drop-shadow(0 0 3px rgba(0, 0, 0, 0.5));
        }
    </style>
}
else
{
    <div class="alert alert-info">
        No carousel items configured for this widget.
    </div>
}
