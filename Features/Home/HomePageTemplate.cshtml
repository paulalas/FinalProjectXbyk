@model TemplateViewModel<HomePageTemplateProperties>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="home-page">
    <!-- Hero Section - Editable Area 1 -->
    <section class="hero-section py-5 bg-light">
        <div class="container">
            <editable-area area-identifier="hero" />
        </div>
    </section>

    <!-- Main Content - Editable Area 2 -->
    <section class="main-content py-5">
        <div class="container">
            <editable-area area-identifier="mainContent" />
        </div>
    </section>

    <!-- Features Section - Editable Area 3 -->
    <section class="features-section py-5 bg-light">
        <div class="container">
            <editable-area area-identifier="features" />
        </div>
    </section>

    <!-- Call to Action - Editable Area 4 -->
    <section class="cta-section py-5">
        <div class="container">
            <editable-area area-identifier="callToAction" />
        </div>
    </section>
</div>
