@using Kentico.PageBuilder.Web.Mvc
@using Kentico.Content.Web.Mvc
@using Kentico.Content.Web.Mvc.PageBuilder
@using Kentico.Web.Mvc
@using CMS.ContentEngine
@using CMS.Websites

@model TemplateViewModel
@inject IWebPageDataContextRetriever webPageDataContextRetriever
@inject IContentRetriever contentRetriever

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pageDataContext = webPageDataContextRetriever.Retrieve();
    var webPageItemGuid = pageDataContext.WebPage.WebPageItemGUID;
    IEnumerable<ArticlesDetail> articlesDetail = await contentRetriever.RetrievePages<ArticlesDetail>(
        new RetrievePagesParameters
        {
            LinkedItemsMaxLevel = 1  // Load linked Assets for ArticleThumbnail
        },
        query => query
            .Where(w => w.WhereEquals(nameof(WebPageFields.WebPageItemGUID), webPageItemGuid))
            .TopN(1),
        new RetrievalCacheSettings($"Article_{webPageItemGuid}", TimeSpan.FromMinutes(5)),
        Context.RequestAborted
    );
}

<div class="articles-detail-page">
    <!-- Thumbnail Section - Wide at the top -->
    @if (articlesDetail.FirstOrDefault()?.ArticleThumbnail != null)
    {
        <section class="thumbnail-section">
            @foreach (var thumbnail in articlesDetail.FirstOrDefault()?.ArticleThumbnail)
            {
                <img src="@thumbnail.Thumbnail.Url" alt="@articlesDetail.FirstOrDefault()?.ArticleTitle" class="img-fluid w-100" />
            }
        </section>
    }

    <!-- Main Content Section -->
    <section class="articles-detail-content py-5">
        <div class="container">
            <!-- Title - Centered -->
            <div class="text-center mb-5">
                <h1 class="article-title">@articlesDetail.FirstOrDefault()?.ArticleTitle</h1>
            </div>

            <!-- Content - Description -->
            <div class="article-description mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        @Html.Raw(articlesDetail.FirstOrDefault()?.ArticleContent)
                    </div>
                </div>
            </div>

            <!-- DateTime - Bottom Right -->
            @if (articlesDetail.FirstOrDefault()?.ArticleDateCreated != null)
            {
                <div class="text-end">
                    <small class="text-muted">
                        Created on: @articlesDetail.FirstOrDefault()?.ArticleDateCreated.ToString("MMMM dd, yyyy")
                    </small>
                </div>
            }
        </div>
    </section>
</div>
